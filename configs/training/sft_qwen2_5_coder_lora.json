{
  "model_name": "Qwen/Qwen2.5-Coder-7B-Instruct",
  "data_dir": "data/mini_repo_debug/hf_training",
  "output_dir": "models/codeguide_sft_qwen2_5_coder_lora",
  "max_seq_length": 2048,
  "use_lora": true,
  "lora_r": 16,
  "lora_alpha": 32,
  "lora_dropout": 0.05,
  "target_modules": [
    "q_proj",
    "k_proj",
    "v_proj",
    "o_proj",
    "gate_proj",
    "up_proj",
    "down_proj"
  ],
  "per_device_train_batch_size": 1,
  "gradient_accumulation_steps": 8,
  "learning_rate": 0.0002,
  "num_train_epochs": 1.0,
  "logging_steps": 1,
  "save_steps": 20,
  "save_total_limit": 2,
  "report_to": "none",
  "torch_dtype": "bf16",
  "bf16": true,
  "fp16": false,
  "device_map": "auto"
}
